<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>
<SplitPane dividerPositions="0.4" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/"
           fx:controller="de.timkodiert.mokka.view.billing.BillingManageView">
    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <Label styleClass="text-bold" text="%manageBilling.label.manageBillings">
                    <font>
                        <Font name="System Bold" size="13.0"/>
                    </font>
                </Label>
                <Button mnemonicParsing="false" onAction="#openNewBilling" styleClass="small" text="%button.add"/>
            </HBox>
        </top>
        <center>
            <TableView fx:id="entityTable" BorderPane.alignment="CENTER">
                <columns>
                    <TableColumn fx:id="titleColumn" editable="false" minWidth="-Infinity" prefWidth="300.0" sortable="false" text="%manageBilling.column.title"/>
                    <TableColumn fx:id="periodColumn" editable="false" minWidth="-Infinity" prefWidth="200.0" sortable="false" text="%manageBilling.column.period"/>
                    <TableColumn fx:id="totalColumn" editable="false" minWidth="-Infinity" prefWidth="150.0" sortable="false" text="%manageBilling.column.total"/>
                </columns>
            </TableView>
        </center>
    </BorderPane>
    <StackPane fx:id="detailViewContainer"/>
</SplitPane>
